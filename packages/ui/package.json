    "gsap": ">=3.12"
  },
  "peerDependenciesMeta": {
    "@react-three/fiber": { "optional": true },
    "@react-three/drei": { "optional": true },
    "three": { "optional": true },
    "gsap": { "optional": true }
  },
  "devDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@react-three/fiber": "^8.15.16",
    "@react-three/drei": "^9.97.6",
    "three": "^0.160.1",
    "framer-motion": "^10.18.0",
    "gsap": "^3.12.5",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "tsdown": "^0.11.0",
    "typescript": "^5.7.0"
  }
