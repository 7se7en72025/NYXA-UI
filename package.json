{
  "name": "nyxa-ui",
  "private": true,
  "version": "0.0.0",
  "description": "NYXA - A constellation-themed UI component library",
  "author": "NYXA",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @nyxa/web dev",
    "build": "turbo build",
    "build:ui": "pnpm --filter @nyxa/ui build",
    "build:web": "pnpm --filter @nyxa/web build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "changeset": "changeset",
    "release": "changeset publish"
  }
}
